{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run seo:prepare",
    "dev": "vite",
    "gen:i18n": "node scripts/gen-i18n.mjs",
    "seo:prepare": "node scripts/generate-archive-data.mjs",
    "seo:check": "node scripts/check-seo-week2.mjs",
    "build": "node scripts/gen-i18n.mjs && npm run seo:prepare && vite-ssg build && node scripts/copy-seo-assets.mjs && npm run seo:check",
    "build:csr": "npm run seo:prepare && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@unhead/vue": "^2.1.15",
    "chart.js": "^4.5.1",
    "opencc-js": "^1.3.1",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "vite": "^8.0.12",
    "vite-ssg": "^28.3.0"
  }
}
