# Caddy 配置 — 部署到服务器 /etc/caddy/Caddyfile
# 改动后跑：sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

www.ckl.hk {
    root * /opt/lottery-analysis/frontend/dist
    file_server
    # 优先返回 SSG 预渲染的 <path>.html（vite-ssg 输出），
    # 不存在再走 SPA fallback 到 /index.html
    try_files {path} {path}.html /index.html
}

api.ckl.hk {
    reverse_proxy localhost:8000
}
